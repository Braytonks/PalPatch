{
	"schemaVersion": 1,
	"id": "palpatch",
	"version": "${version}",
	"name": "PalPatch",
	"description": "Finding holes in Minecraft's color palette and proposing solutions!",
	"authors": [
		"Braytonks"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/palpatch/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"bray.palpatch.PalPatch"
		],
		"fabric-datagen": [
			"bray.palpatch.PalPatchDataGenerator"
		],
		"client": [
			"bray.palpatch.PalPatchClient"
		]
	},
	"mixins": [
		"palpatch.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.18.6",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*"
	}
}